# --- Local dev: copy this file to `frontend/.env` and fill real values ---
# Cloud Shell cannot set this file on your PC — paste VITE_GOOGLE_CLIENT_ID on the machine that runs npm run dev.

# Backend API: leave unset or empty to use Vite's `/api` proxy → http://localhost:8080 (see vite.config.js).
# Set only if you call the API on another host/port (then CORS on the backend must allow your dev origin).
# VITE_API_BASE_URL=http://localhost:8080

# Google Identity Services — OAuth 2.0 *Web* client ID (NOT Android/iOS).
# Create: https://console.cloud.google.com/apis/credentials → Create credentials → OAuth client ID → Web application
# Authorized JavaScript origins (add every URL you use in the browser):
#   http://localhost:5173
#   http://localhost:5174
#   http://localhost:5175
# If the app is "Testing" on OAuth consent screen, add your Gmail under Test users.
# Paste your Web client id on the next line (no quotes)
VITE_GOOGLE_CLIENT_ID=

# Backend (optional): same Web client ID verifies the Google ID token "aud" claim at /api/auth/google
# Export when running Spring Boot, or set in IDE run config: GOOGLE_OAUTH_WEB_CLIENT_ID=....apps.googleusercontent.com
